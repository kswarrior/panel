<%- include('../components/header', { title: 'Login'}) %>
<style>
/* ================= BODY ================= */
body {
  /* Background image with dark overlay */
  background:
    linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)),
    url('/assets/background.webp') center/cover no-repeat;

  color: var(--text);
  font-family: var(--font-family);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100dvh;
  user-select: none;
  margin: var(--margin-body);
}

/* ================= CARD ================= */
.card {
  padding: var(--card-padding);
  width: 100%;
  max-width: 400px;
  backdrop-filter: blur(var(--backdrop-blur));
  background: rgba(0, 0, 0, 0.4);
  border-radius: var(--card-radius);
  display: flex;
  flex-direction: column;
  gap: var(--gap);
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

.card h2 {
  font-size: var(--h2-size);
  margin-bottom: 8px;
  font-weight: 800;
}

.card p {
  color: var(--muted);
  font-size: var(--p-size);
  margin-bottom: 15px;
}

/* ================= INPUTS ================= */
.input-label {
  display: block;
  margin-bottom: 6px;
  font-size: var(--label-size);
  font-weight: var(--label-font-weight);
}

.input-field {
  width: calc(100% - 36px);
  padding: var(--input-padding);
  border-radius: var(--input-radius);
  border: 1px solid var(--border);
  background: var(--soft);
  color: var(--text);
  transition: all var(--transition);
  font-size: var(--p-size);
  margin-bottom: 8px;
}

.input-field:focus {
  border-color: var(--accent);
  outline: none;
}

/* ================= CHECKBOX ================= */
.checkbox {
  accent-color: blue;
  margin-right: 8px;
}

/* ================= LINKS ================= */
.link {
  color: var(--accent);
  font-size: var(--link-size);
  text-decoration: none;
  transition: color 0.3s;
  display: inline-block;
  margin-bottom: 8px;
}

.link:hover {
  color: var(--accent-glow);
}

/* ================= BUTTON ================= */
.btn {
  padding: var(--btn-padding);
  border-radius: var(--btn-radius);
  border: none;
  background: var(--accent);
  color: #000;
  width: 100%;
  font-weight: var(--btn-font-weight);
  cursor: pointer;
  transition: all var(--transition);
  box-shadow: var(--btn-shadow);
}

.btn:hover {
  transform: scale(1.03);
}

/* ================= RESPONSIVE ================= */
@media (max-width: 480px) {
  .card {
    padding: var(--card-padding-mobile);
  }
}
</style>

<div class="card">
  <div>
    <% if (settings.logo) { %><img class="h-12 w-auto rounded-xl" src="<%= settings.logo %>"> <% } %>
    <h2 class="<% if (settings.logo == true) { %>mt-6<% } %>">Sign in to <%= settings.title %></h2>
    <p>Please enter your account credentials below.</p>
  </div>

  <!-- Error Messages Section -->
  <% if (req.query.err) { %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
            <% if (req.query.err === 'missing_credentials') { %>
              Missing Information
            <% } else if (req.query.err === 'invalid_credentials') { %>
              Invalid Credentials
            <% } else if (req.query.err === 'user_not_found') { %>
              User Not Found
            <% } else if (req.query.err === 'incorrect_password') { %>
              Incorrect Password
            <% } else if (req.query.err === 'database_error') { %>
              Server Error
            <% } else if (req.query.err === 'registration_disabled') { %>
              Registration Disabled
            <% } else { %>
              Login Error
            <% } %>
          </h3>
          <div class="mt-2 text-sm text-red-700 dark:text-red-300">
            <% if (req.query.err === 'missing_credentials') { %>
              Please enter both your username/email and password.
            <% } else if (req.query.err === 'invalid_credentials') { %>
              The username/email or password you entered is incorrect. Please check your credentials and try again.
            <% } else if (req.query.err === 'user_not_found') { %>
              No account found with that username or email address. Please check your input or create a new account.
            <% } else if (req.query.err === 'incorrect_password') { %>
              The password you entered is incorrect. Please try again or use the "Forgot Password" option.
            <% } else if (req.query.err === 'database_error') { %>
              We're experiencing technical difficulties. Please try again in a few moments.
            <% } else if (req.query.err === 'registration_disabled') { %>
              Registration is currently disabled. Please contact an administrator if you need an account.
            <% } else { %>
              An unexpected error occurred. Please try again.
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <form id="login-form" class="space-y-6" action="/login" method="POST">
    <%- include('../components/csrf') %>

    <div>
      <label for="username" class="input-label">Username or Email</label>
      <input class="input-field"
             name="identifier"
             placeholder="example"
             id="username"
             autocomplete="username"
             required>
    </div>

    <div>
      <label for="password" class="input-label">Password</label>
      <input class="input-field"
             id="password"
             name="password"
             placeholder="********"
             type="password"
             autocomplete="current-password"
             required>
    </div>

    <div style="display: flex; align-items: center; gap: 6px;">
      <input class="checkbox"
             id="remember-me"
             name="remember-me"
             type="checkbox">
      <span class="input-label">Remember me</span>
    </div>

    <div>
      <a class="link" href="/forgot-password">Forgot your password?</a>
    </div>

    <div>
      <button class="btn" type="submit">Sign in</button>
    </div>

    <% if (settings.register) { %>
    <div class="mt-6 text-sm text-neutral-500 py-[-50px]">
      Need an account? <a href="/register" class="link">Register</a>
    </div>
    <% } %>
  </form>
</div>

<%- include('../components/footer') %>
