<!-- ============================================================================= -->
<!--                          SIDEBAR + TOPBAR - FIXED VERSION                     -->
<!-- ============================================================================= -->

<style>
  :root {
    --backdrop-blur: 12px;
  }

  /* Reset / base fixes */
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    overflow-x: hidden;
  }

  /* ── MOBILE SIDEBAR ──────────────────────────────────────────────── */
  @media (max-width: 1023px) {  /* lg = 1024px */
    #mobile-sidebar {
      position: fixed;
      inset: 0;
      z-index: 60;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    #mobile-sidebar.open {
      pointer-events: auto;
      opacity: 1;
    }

    #mobile-sidebar-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(var(--backdrop-blur));
      -webkit-backdrop-filter: blur(var(--backdrop-blur));
      opacity: 0;
      transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    #mobile-sidebar.open #mobile-sidebar-backdrop {
      opacity: 1;
    }

    #mobile-sidebar-content {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 280px;
      max-width: 85vw;
      transform: translateX(-100%);
      transition: transform 0.42s cubic-bezier(0.165, 0.84, 0.44, 1);
      will-change: transform;
    }

    #mobile-sidebar.open #mobile-sidebar-content {
      transform: translateX(0);
    }
  }

  /* ── DESKTOP SIDEBAR ─────────────────────────────────────────────── */
  @media (min-width: 1024px) {
    #pc-sidebar {
      position: fixed;
      inset-y: 0;
      left: 0;
      z-index: 50;
      width: 14rem;          /* 56 * 0.25rem = 224px ≈ 14rem */
      transition: width 0.3s ease;
    }

    #pc-sidebar.collapsed {
      width: 4.5rem;
    }

    #pc-sidebar .group\\/collapsed\\:hidden {
      display: none;
    }
  }

  /* Active link background */
  #active-background {
    position: absolute;
    left: 0.5rem;
    right: 0.5rem;
    height: 2.5rem;
    background: rgba(255,255,255,0.08);
    border-radius: 0.75rem;
    pointer-events: none;
    transition: all 0.28s ease;
  }

  /* Topbar fixes */
  #topbar {
    position: sticky;
    top: 0;
    z-index: 40;
    height: 4rem;
    backdrop-filter: blur(var(--backdrop-blur));
    -webkit-backdrop-filter: blur(var(--backdrop-blur));
    background: rgba(15, 23, 42, 0.4);   /* slate-900 / 40% */
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  @media (max-width: 1023px) {
    #topbar {
      padding-top: env(safe-area-inset-top);
    }
  }

  /* Common utility */
  .nav-link {
    position: relative;
    z-index: 1;
  }

  .nav-link.active {
    color: white !important;
    font-weight: 500;
  }
</style>

<!-- ── MOBILE HAMBURGER ─────────────────────────────────────────────── -->
<button id="mobile-sidebar-toggle"
  class="lg:hidden fixed top-4 left-4 z-70 flex items-center justify-center w-10 h-10 rounded-xl bg-slate-900/70 border border-white/10 text-white hover:bg-slate-800 active:scale-95 transition-all duration-150">
  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
  </svg>
</button>

<!-- ── MOBILE SIDEBAR (overlay style) ───────────────────────────────── -->
<div id="mobile-sidebar" class="lg:hidden">
  <div id="mobile-sidebar-backdrop"></div>
  <div id="mobile-sidebar-content" class="bg-slate-950/95 border-r border-white/6 backdrop-blur-xl overflow-y-auto">
    <!-- Content almost same as desktop sidebar – extract to partial if using template engine -->
    <div class="flex flex-col h-full">
      <!-- Logo + title -->
      <div class="p-5 border-b border-white/5">
        <a href="/" class="flex items-center gap-3">
          <img src="<%= settings.logo.startsWith('/') ? settings.logo : '/' + settings.logo %>" alt="Logo"
               class="h-10 w-10 rounded-xl bg-neutral-950/80 p-1">
          <h1 class="text-white font-semibold tracking-tight text-xl"><%= settings.title %></h1>
        </a>
      </div>

      <!-- User info -->
      <div class="flex items-center gap-3 px-5 py-5 border-b border-white/5">
        <img class="h-10 w-10 rounded-xl border border-neutral-700/30"
             src="https://api.dicebear.com/9.x/thumbs/svg?seed=<%= encodeURIComponent(user.username) %>" alt="">
        <div>
          <div class="font-medium text-white"><%= user.username %>
            <sup class="text-xs text-neutral-500">#<%= String(user.id).padStart(4, '0') %></sup>
          </div>
          <div class="text-xs text-neutral-400 mt-0.5"><%= user.description || '—' %></div>
        </div>
      </div>

      <!-- Navigation links (same structure as desktop) -->
      <nav class="flex-1 px-3 py-6">
        <ul class="space-y-1 relative">
          <div id="active-background-mobile"></div>
          <!-- ... paste your regular nav items here (same as below) ... -->
          <!-- For brevity I'm not duplicating all items – copy from desktop <ul> below -->
        </ul>
      </nav>

      <!-- Logout -->
      <div class="p-3 border-t border-white/5 mt-auto">
        <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-neutral-400 hover:text-red-400 hover:bg-red-950/30 transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0110.5 3h6a2.25 2.25 0 012.25 2.25v13.5A2.25 2.25 0 0116.5 21h-6a2.25 2.25 0 01-2.25-2.25V15m-3 0l-3-3m0 0l3-3m-3 3H15" />
          </svg>
          <span>Logout</span>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- ── DESKTOP SIDEBAR ───────────────────────────────────────────────── -->
<div id="pc-sidebar" class="hidden lg:flex lg:flex-col transition-all duration-300">
  <div class="flex min-h-0 flex-1 flex-col border-r border-white/5 bg-slate-950/40 backdrop-blur-lg">
    <!-- Logo -->
    <div class="flex items-center px-5 pt-5 pb-4">
      <a href="/" class="flex items-center gap-3">
        <img src="<%= settings.logo.startsWith('/') ? settings.logo : '/' + settings.logo %>" alt="Logo"
             class="h-10 w-10 rounded-xl bg-neutral-950/80 p-1">
        <h1 class="text-lg font-semibold text-white tracking-tight group-[.collapsed]:hidden"><%= settings.title %></h1>
      </a>
    </div>

    <!-- User -->
    <div class="flex items-center gap-3 px-4 py-4 border-y border-white/5">
      <img class="h-9 w-9 rounded-xl border border-neutral-700/20"
           src="https://api.dicebear.com/9.x/thumbs/svg?seed=<%= encodeURIComponent(user.username) %>" alt="">
      <div class="group-[.collapsed]:hidden">
        <div class="font-medium text-white text-sm">
          <%= user.username %><sup class="text-xs text-neutral-500 ml-1">#<%= String(user.id).padStart(4, '0') %></sup>
        </div>
        <div class="text-xs text-neutral-400"><%= user.description || '—' %></div>
      </div>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-5">
      <ul class="relative space-y-1">
        <div id="active-background"></div>
        <!-- Your navigation items go here – same as your original code -->
        <!-- Example placeholder: -->
        <li>
          <a href="/servers" class="nav-link group flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-300 rounded-xl hover:bg-white/5 transition-colors">
            <svg class="w-5 h-5" ... > ... </svg>
            <span class="group-[.collapsed]:hidden">Servers</span>
          </a>
        </li>
        <!-- ... more items ... -->
      </ul>
    </nav>

    <!-- Logout -->
    <div class="border-t border-white/5 p-3">
      <a href="/logout" class="flex items-center gap-3 px-4 py-3 text-sm text-neutral-400 rounded-xl hover:bg-red-950/20 hover:text-red-400 transition-colors">
        <svg class="w-5 h-5" ... > ... </svg>
        <span class="group-[.collapsed]:hidden">Logout</span>
      </a>
    </div>
  </div>
</div>

<!-- ── TOP BAR ────────────────────────────────────────────────────────── -->
<div id="topbar">
  <div class="flex h-full items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Left side – hamburger on mobile, collapse button on desktop -->
    <div class="flex items-center gap-4">
      <button id="sidebar-toggle" type="button"
        class="hidden lg:flex items-center justify-center w-9 h-9 rounded-lg border border-white/10 text-neutral-300 hover:text-white hover:bg-white/5 transition-all">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>

    <!-- Center / brand -->
    <div class="flex items-center gap-3">
      <% if (settings.logo) { %>
        <img class="h-8 w-8 rounded-lg" src="<%= settings.logo %>" alt="Logo">
      <% } %>
      <div>
        <h2 class="text-lg font-semibold text-white"><%= settings.title %></h2>
        <p class="text-xs text-neutral-400"><%= title || 'Dashboard' %></p>
      </div>
    </div>

    <!-- Right side – can add user menu, notifications, etc. -->
    <div></div>
  </div>
</div>

<!-- Main content offset -->
<div id="colcont" class="lg:pl-56 min-h-screen">
  <!-- Your page content here -->
</div>

<script>
// ── JavaScript ────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const mobileToggle   = document.getElementById('mobile-sidebar-toggle');
  const mobileSidebar  = document.getElementById('mobile-sidebar');
  const desktopSidebar = document.getElementById('pc-sidebar');
  const desktopToggle  = document.getElementById('sidebar-toggle');

  // Mobile open/close
  mobileToggle?.addEventListener('click', () => {
    mobileSidebar?.classList.toggle('open');
  });

  // Click outside → close mobile
  document.addEventListener('click', e => {
    if (mobileSidebar?.classList.contains('open') &&
        !mobileSidebar.contains(e.target) &&
        !mobileToggle.contains(e.target)) {
      mobileSidebar.classList.remove('open');
    }
  });

  // Desktop collapse
  desktopToggle?.addEventListener('click', () => {
    desktopSidebar?.classList.toggle('collapsed');
  });

  // Active link highlight (very basic version – improve as needed)
  const links = document.querySelectorAll('.nav-link');
  const activeBg = document.getElementById('active-background') ||
                   document.getElementById('active-background-mobile');

  if (activeBg && links.length > 0) {
    const setActive = (target) => {
      if (!target) return;
      const rect = target.getBoundingClientRect();
      const parentRect = target.closest('ul')?.getBoundingClientRect();
      if (!parentRect) return;

      activeBg.style.height = `${rect.height}px`;
      activeBg.style.transform = `translateY(${rect.top - parentRect.top + target.closest('ul').scrollTop}px)`;
      activeBg.style.opacity = '1';
    };

    links.forEach(link => {
      link.addEventListener('click', () => {
        links.forEach(l => l.classList.remove('active'));
        link.classList.add('active');
        setActive(link);
      });
    });

    // Initial
    const current = Array.from(links).find(l => {
      return l.getAttribute('href') === window.location.pathname ||
             window.location.pathname.startsWith(l.getAttribute('href'));
    });
    if (current) {
      current.classList.add('active');
      setActive(current);
    }
  }
});
</script>
