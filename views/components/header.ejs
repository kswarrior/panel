<!DOCTYPE html>
<html class="h-full" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% if (typeof csrfToken !== 'undefined') { %>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <% } %>
    <title><%= settings.title %> - <%= title %></title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="icon" href="<%= settings.favicon %>" type="image/x-icon">
    <link rel="shortcut icon" href="<%= settings.favicon %>" type="image/x-icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.fontshare.com">
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@500,300,600,400,700&display=swap" rel="stylesheet">
    <script src="/js/csrf.js"></script>
</head>
<body style="font-family: 'General Sans'" class="bg-white dark:bg-[#141414] h-full text-neutral-800 dark:text-white">
<button id="theme-toggle" class="absolute right-4 top-4 w-14 h-8 flex items-center bg-gray-300 dark:bg-neutral-700/70 rounded-full p-1 transition-colors duration-500 z-50">
    <span class="dot bg-white w-6 h-6 rounded-full shadow-md transform transition-transform duration-500 border border-neutral-950/20"></span>
</button>
<script>
function initializeTheme() {
    const userPreference = localStorage.getItem('theme');
    const systemPreference = window.matchMedia('(prefers-color-scheme: dark)').matches;

    if (userPreference === 'dark' || (!userPreference && systemPreference)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    updateSwitchPosition();
  }

  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateSwitchPosition();
    if (typeof setTerminalTheme === 'function') {
    setTerminalTheme();
  }
  }

  function updateSwitchPosition() {
    const isDark = document.documentElement.classList.contains('dark');
    const dot = document.querySelector('#theme-toggle .dot');
    if (isDark) {
      dot.classList.add('translate-x-6');
    } else {
      dot.classList.remove('translate-x-6');
    }
  }

  document.getElementById('theme-toggle').addEventListener('click', toggleTheme);
  initializeTheme();
  </script>

<!-- Added sidebar like in the referenced template -->
<style>
   .sidebar nav ul {
      position: relative;
   }
   .nav-link {
      position: relative;
      z-index: 1;
   }
   .nav-link.active {
      color: white;
      font-weight: 500;
   }
   @media (max-width: 1024px) {
      .sidebar {
         display: none;
         position: fixed;
         z-index: 50;
         height: 100%;
         width: 225px;
         backdrop-filter: blur(var(--backdrop-blur));
         background: rgba(0, 0, 0, 0.4);
         overflow-y: auto;
         /* Original transform */
         transform: translateX(-100%);
         /* Added smooth animation */
         opacity: 0;
         transition: 
            transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
            opacity 0.3s ease;
      }

      .sidebar.open {
         display: block;
         transform: translateX(0);
         /* Added fade in */
         opacity: 1;
         animation: sidebarSlide 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .sidebar.expanded {
         width: 100%;
      }
   }

   /* Animation */
   @keyframes sidebarSlide {
      from {
         transform: translateX(-110%);
         opacity: 0;
      }
      to {
         transform: translateX(0);
         opacity: 1;
      }
   }
</style>

<script>
   document.addEventListener('DOMContentLoaded', () => {
      const sidebar = document.getElementById('pc-sidebar');
      const sidebar2 = document.getElementById('pc-sidebar2');
      const colcont = document.getElementById('colcont');

      <% if (typeof theme !== 'undefined' && theme) { %>
      if ('<%= theme["sidebar-direction"] %>' === 'right') {
         if (sidebar) sidebar.classList.add('right-0');
         if (colcont) {
            colcont.classList.add('colcontextream');
            colcont.classList.add('colcont-right');
         }
         if (sidebar2) {
            sidebar2.classList.remove('rounded-r-3xl', 'rounded-l-lg');
            sidebar2.classList.add('rounded-r-lg', 'rounded-l-3xl');
         }
      } else {
         if (sidebar) sidebar.classList.add('left-0');
      }
      <% } else { %>
      if (sidebar) sidebar.classList.add('left-0');
      <% } %>
   });
</script>

<!-- MOBILE TOGGLE SECTION -->
<button id="mobile-sidebar-toggle" class="lg:hidden fixed top-4 left-4 z-50 w-fit p-2 rounded-xl text-white border border-white/5 bg-[#162836] hover:scale-110 active:scale-100 duration-200 transition-all">
   <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
   </svg>
</button>
<!-- Static sidebar for desktop -->
<div id="pc-sidebar" class="sidebar transition-all duration-300 ease-in-out hidden lg:fixed lg:inset-y-0 lg:z-50 p-2 lg:flex lg:w-56 lg:flex-col group group-[.collapsed]:w-[4%]">
   <div id="pc-sidebar2" class="flex grow flex-col gap-y-5 overflow-hidden rounded-r-3xl rounded-l-lg bg-transparent border border-white/5">
      <nav class="flex flex-1 flex-col">
         <!-- USER INFO SECTION -->
         <div class="flex items-center space-x-4 py-4 px-4 border-y border-white/5">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
               <!-- Head -->
               <circle cx="14" cy="8.5" r="5.5" fill="#ffffff"/>
               <!-- Body with smooth transition and nicer shoulders -->
               <path 
                  d="M7 22 
                     C7 17.5 9.5 14.5 14 14.5 
                     C18.5 14.5 21 17.5 21 22 
                     L21 24 
                     C21 25.1 20.1 26 19 26 
                     L9 26 
                     C7.9 26 7 25.1 7 24 Z" 
                  fill="#ffffff"
               />
            </svg>
            <div class="group-[.collapsed]:hidden">
               <p class="text-sm font-medium text-white"><%= user.username %></p>
               <p class="text-xs text-neutral-500"><%= user.userId.substring(0, 6) %></p>
            </div>
         </div>
         <ul role="list" class="flex flex-1 flex-col gap-y-7 mt-2">
            <li>
               <ul role="list" class="-mx-2 space-y-1">
                  <div id="active-background" class="absolute left-0 w-full h-8 bg-white/5 rounded-2xl transition-all duration-300 ease-in-out"></div>
                  <li>
                     <a href="/instances" class="transition-all duration-300 ease-in-out nav-link mt-1 text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal" searchdata="container instances servers" subterm="jegli:/server/servername">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-5 mt-0.5 h-5 group-[.collapsed]:mr-0"><rect width="256" height="256" fill="none"/><path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/><path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/><path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0,0,0,0,13.82Z"/></svg>
                        <span class="group-[.collapsed]:hidden"><%= req.translations.instances %></span>
                     </a>
                     <a href="/account" searchdata="account profile <%= user.username %>" class="transition-all duration-300 ease-in-out nav-link mt-1 text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 mt-0.5 h-5 group-[.collapsed]:mr-0">
                           <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                        </svg>                                                           
                        <span class="group-[.collapsed]:hidden"><%= req.translations.account %></span>
                     </a>
                     <% plugins.forEach(plugin => { %>
                        <% if (plugin.sidebar) { %>
                           <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                              <a href="<%= value.url %>" searchdata="<%= value.search_data %>" class="transition nav-link mt-1 text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                                 <% if (value.icon) { %>
                                    <span class="svg-icon" data-icon-url="<%= value.icon %>"></span>
                                 <% } else { %>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 mt-0.5 h-5">
                                       <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                                    </svg>
                                 <% } %>
                                 <span><%= key %></span>
                              </a>
                           <% }); %>
                        <% } %>
                     <% }); %>
                     
                     <script>
                        document.addEventListener("DOMContentLoaded", function() {
                           document.querySelectorAll('.svg-icon').forEach(function(span) {
                              const url = span.getAttribute('data-icon-url');
                  
                              fetch(url)
                                 .then(response => {
                                    if (!response.ok) {
                                       throw new Error('Network response was not ok');
                                    } else if (response.status !== 200) {
                                       throw new Error(`Request failed with status ${response.status}`);
                                    } else if (!response.text().includes('<svg')) {
                                       throw new Error('Response does not contain an SVG');
                                    }
                                    return response.text();
                                 })
                                 .then(svgContent => {
                                    span.innerHTML = svgContent;
                                 })
                                 .catch(error => {
                                    console.error('Error on Loading the SVG:', error);
                                 });
                           });
                        });
                     </script>
                     
                     
                     
                  </li>
                  <% if (typeof user !== 'undefined' && user && user.admin == true) { %>
                     <p class="pl-8 pt-6 pb-2 text-sm md:text-base font-semibold uppercase tracking-wide text-white group-[.collapsed]:hidden">
                        <span>Admin Panel</span>
                     </p>
                     <li>
                        <a href="/admin/overview" searchdata="admin overview control" class="transition-all duration-300 ease-in-out nav-link mt-1 text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                           <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-5 mt-0.5 h-5 group-[.collapsed]:mr-0"><rect width="256" height="256" fill="none"/><path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/><path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/><path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0,0,0,0,13.82Z"/></svg>
                           <span class="group-[.collapsed]:hidden">Overview</span>
                        </a>
                     </li>
                  <% } %>
               </ul>
            </li>
         </ul>
      </nav>
   </div>
</div>
