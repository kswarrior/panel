{
  "name": "ks-panel",
  "version": "1.0.0",
  "description": "KS Panel is a modern server management panel built by kswarrior",
  "repository": {
    "type": "git",
    "url": "https://github.com/kswarrior/ks-panel"
  },
  "author": "kswarrior",
  "license": "MIT",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "create:user": "npx ts-node src/handlers/cmd/createUser.ts",
    "build:css": "npx tailwindcss -i ./public/tw.css -o ./public/styles.css --watch",
    "migrate:dev": "npx prisma migrate dev --name init && npx prisma generate",
    "migrate:deploy": "npx prisma migrate deploy && npx prisma generate",
    "seed": "ts-node src/handlers/cmd/seed.ts",
    "lint": "eslint src --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "consola": "^3.4.2",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-ws": "^5.0.2",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "multer": "^2.0.2",
    "prisma": "^6.19.2",
    "socket.io": "^4.7.5",
    "ws": "^8.14.2",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/csurf": "^1.11.5",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/fs-extra": "^11.0.4",
    "@types/helmet": "^4.0.0",
    "@types/hpp": "^0.2.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.8.6",
    "@types/ws": "^8.5.14",
    "eslint": "^9.15.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
